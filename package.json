{
	"name": "tauri-plugin-module-federation",
	"private": true,
	"packageManager": "pnpm@10.28.2",
	"scripts": {
		"build": "pnpm --dir module-federation-plugin build && pnpm build:package:cargo",
		"build:package": "pnpm build",
		"build:package:cargo": "cargo package --manifest-path tauri-plugin/Cargo.toml --allow-dirty --no-verify",
		"changeset": "changeset",
		"changeset:status": "changeset status",
		"release:sync": "node scripts/sync-release-version.mjs",
		"release:sync:check": "node scripts/sync-release-version.mjs --check"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.7"
	}
}
